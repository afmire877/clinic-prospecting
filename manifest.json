{
  "manifest_version": 3,
  "name": "llms.txt Page Copier",
  "version": "1.0",
  "description": "Copy current page in llmstxt.org format",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://api.openai.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Copy as llms.txt"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
}