#!/usr/bin/env node

const path = require('path');
const fs = require('fs');

const distEntry = path.join(__dirname, '..', 'dist', 'cli.js');
const srcEntry = path.join(__dirname, '..', 'src', 'cli.ts');

if (fs.existsSync(distEntry)) {
  require(distEntry);
} else if (fs.existsSync(srcEntry)) {
  require('ts-node').register({ project: path.join(__dirname, '..', 'tsconfig.json') });
  require(srcEntry);
} else {
  console.error('Error: Could not find CLI entry point. Run "npm run build" first.');
  process.exit(1);
}
